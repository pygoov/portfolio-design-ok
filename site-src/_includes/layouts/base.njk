<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="{{ metaDescription or 'Портфолио дизайнера Олеси Караульных: работы, кейсы и визуальные системы.' }}"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="{{ page.url | rootPrefix }}site.css" />
    <title>{% if title %}{{ title }} | {% endif %}Олеся Караульных</title>
  </head>
  <body id="top">
    {% set root = page.url | rootPrefix %}
    <div class="page-shell">
      {% include "blocks/site-header.njk" %}
      <main>{{ content | safe }}</main>
      {% include "blocks/site-footer.njk" %}
    </div>
  </body>
</html>
